# ============================================================
#  O.R.B.I.T.A. — Template de Variaveis de Ambiente
#  Copie este arquivo para .env e preencha com sua chave.
#  O arquivo .env NUNCA vai para o GitHub (bloqueado no .gitignore).
# ============================================================

# Sua chave do Google AI Studio (https://aistudio.google.com/apikey)
# Crie uma conta gratuita (sem cartao) e gere a chave — comeca com "AIza..."
GEMINI_API_KEY=COLE_SUA_CHAVE_GEMINI_AQUI

# Modelo usado pela ARIA. Sugestoes (todos no free tier):
#   gemini-2.5-flash       (recomendado — rapido e inteligente)
#   gemini-2.0-flash       (alternativa mais leve)
#   gemini-2.5-flash-lite  (mais rapido ainda)
GEMINI_MODEL=gemini-2.5-flash

# ----- ALTERNATIVA: OpenRouter (se preferir, comente as linhas acima
#       e descomente as de baixo) -----
# OPENROUTER_API_KEY=sk-or-v1-suachave
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
